#!/bin/sh

echo "Running pre-commit checks..."

# Get staged files
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACMR)
echo "Staged files:"
echo "$STAGED_FILES" | sed 's/^/  /'
if [ -z "$STAGED_FILES" ]; then
  echo "No staged files to process"
  exit 0
fi
echo ""

# Format all staged files
echo "Running Prettier..."
PRETTIER_FILES=$(echo "$STAGED_FILES" | sed 's| |\\ |g')
if [ -n "$PRETTIER_FILES" ]; then
  echo "  Formatting files..."
  prettier $PRETTIER_FILES --write --ignore-unknown
  echo "  Prettier completed"
else
  echo "  No files to format"
fi
echo ""

echo "Running ESLint..."
# lint only JS/TS files
ESLINT_FILES=$(echo "$STAGED_FILES" | grep -E '\.(js|ts|tsx)$' | sed 's| |\\ |g')
if [ -n "$ESLINT_FILES" ]; then
  echo "  Linting files:"
  echo "$ESLINT_FILES" | sed 's/^/    /'
  eslint $ESLINT_FILES --fix
  echo "  ESLint completed"
else
  echo "  No JS/TS files to lint"
fi
echo ""

# Add the formatted files back to the index
echo "Updating git index..."
git update-index --again

echo "Pre-commit checks completed successfully!"