---
import Layout from "@/layouts/Layout.astro";
---

<Layout
  title="Stateless Link Chain"
  description="Game state lives in the URL. Create a chain, add players, share the link — no server-side storage."
>
  <main class="min-h-screen bg-zinc-50 text-zinc-900">
    <div class="mx-auto max-w-2xl px-4 py-16">
      <h1 class="text-2xl font-semibold tracking-tight text-zinc-900">
        Stateless Link Chain
      </h1>
      <p class="mt-2 text-zinc-600">
        Game state lives in the URL. Create a chain, add players, share the link
        — no server-side storage.
      </p>
      <div class="mt-6 flex flex-wrap gap-3">
        <a
          href="/play/zip/create"
          class="inline-flex items-center rounded-lg border border-emerald-500 bg-white px-4 py-2 text-sm font-medium text-emerald-600 hover:bg-emerald-50 focus:ring-2 focus:ring-emerald-400 focus:ring-offset-2 focus:ring-offset-white focus:outline-none"
        >
          Create Zip game
        </a>
      </div>
    </div>
  </main>
</Layout>
