---
import Layout from "@/layouts/Layout.astro";
---

<Layout>
  <main class="min-h-screen bg-zinc-50 text-zinc-900">
    <div class="mx-auto max-w-2xl px-4 py-16">
      <h1 class="text-2xl font-semibold tracking-tight text-zinc-900">
        Stateless Link Chain
      </h1>
      <p class="mt-2 text-zinc-600">
        Game state lives in the URL. Create a chain, add players, share the link
        — no server-side storage.
      </p>
      <a
        href="/play"
        class="mt-6 inline-flex items-center rounded-lg bg-blue-600 px-4 py-2 text-sm font-medium text-white hover:bg-blue-400 focus:ring-2 focus:ring-blue-400 focus:ring-offset-2 focus:ring-offset-white focus:outline-none"
      >
        Open test UI →
      </a>
    </div>
  </main>
</Layout>
